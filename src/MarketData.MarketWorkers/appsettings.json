{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/marketworkers-.log",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },

  "ServiceWorker": {
    "ServiceName": "MarketData.MarketWorkers",
    "VenueId": "US-EQ",
    "DashboardPath": "/hangfire",
    "Heartbeat": {
      "EventEndpoint": "tcp://*:9101",
      "IntervalMs": 5000
    }
  },

  "Schedules": {
    "Jobs": [
      {
        "JobKey": "hello-world",
        "Trigger": "Cron",
        "Cron": "*/15 * * * * *",
        "Enabled": true
      },
      {
        "JobKey": "fetch-todo",
        "Trigger": "IntervalAlways",
        "IntervalMinutes": 1,
        "Enabled": true
      }
    ]
  },

  "Persistence": {
    "JsonRootPath": "data",
    "DefaultBackend": "Json",
    "Stores": {
      "Todo": "Json"
    }
  },

  "Hangfire": {
    "DbPath": "C:\\ProgramData\\MarketData\\hangfire.db"
  },

  "AllowedHosts": "*"
}
