{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/serviceworker-.log",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },

  "ServiceWorker": {
    "ServiceName": "MarketData.ServiceWorkers",
    "VenueId": "US-EQ",
    "HeartbeatInterval": "00:01:00",
    "DashboardPath": "/hangfire"
  },

  "Schedules": {
    "Jobs": [
      {
        "JobKey": "hello-world",
        "Trigger": "Cron",
        "Cron": "*/15 * * * * *",
        "Enabled": true
      },
      {
        "JobKey": "exchange-rates",
        "Trigger": "IntervalAlways",
        "IntervalMinutes": 1,
        "Enabled": true
      }
    ]
  },

  "TreasuryApi": {
    "BaseUrl": "https://api.fiscaldata.treasury.gov/services/api/fiscal_service/",
    "FromDate": "2015-01-01",
    "Timeout": "00:00:30"
  },

  "Persistence": {
    "JsonRootPath": "data",
    "DefaultBackend": "Json",
    "Stores": {
      "ExchangeRate": "Json"
    }
  },

  "Hangfire": {
    "DbPath": "C:\\ProgramData\\MarketData\\hangfire.db"
  },

  "AllowedHosts": "*"
}
